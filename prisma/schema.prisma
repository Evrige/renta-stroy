generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

enum ListingType {
  SALE
  RENT
}

enum RentPeriod {
  DAILY
  MONTHLY
}

enum PropertyStatus {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  INACTIVE
}

enum PropertyApprovalStatus {
  DRAFT
  PENDING_REVIEW
  NEEDS_REVISION
  APPROVED
  REJECTED
}

enum RequestType {
  BUY
  RENT
  VIEWING
  CONSULTATION
}

enum PropertyType {
  APARTMENT
  HOUSE
  OFFICE
  COMMERCIAL
  WAREHOUSE
  MALL
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  COMPLETED
}

enum TransactionType {
  SALE
  RENT
}

enum TransactionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  passwordHash String
  phone     String?  @db.VarChar(30)
  avatar    String   @default("/images/avatar.jpg")
  role      UserRole @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  managedProperties Property[] @relation("ManagerProperties")
  requests          Request[]
  favorites         Favorite[]
  reviews           Review[]

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  buyerTransactions  Transaction[] @relation("BuyerTransactions")
  sellerTransactions Transaction[] @relation("SellerTransactions")
  authSessions       AuthSession[]
  ownedProperties    Property[]    @relation("OwnedProperties")
  createdProperties  Property[]    @relation("CreatedProperties")
  reviewedProperties Property[]    @relation("ReviewedProperties")
}

model AuthSession {
  id         String   @id
  tokenHash  String   @unique
  userAgent  String?  @db.VarChar(512)
  ipAddress  String?  @db.VarChar(64)
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Property {
  id           Int            @id @default(autoincrement())
  title        String         @db.VarChar(255)
  slug         String         @unique @db.VarChar(255)
  description  String
  listingType  ListingType
  propertyType PropertyType
  rentPeriod   RentPeriod?
  price        Decimal        @db.Decimal(12, 2)
  area         Decimal        @db.Decimal(10, 2)
  rooms        Int?
  floor        Int?
  totalFloors  Int?
  bathrooms    Int?
  parking      Boolean        @default(false)
  furnished    Boolean        @default(false)
  status       PropertyStatus @default(AVAILABLE)
  approvalStatus PropertyApprovalStatus @default(APPROVED)
  moderationNotes String?
  publishedAt  DateTime?
  reviewedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  managerId   Int?
  locationId  Int
  ownerId     Int?
  createdById Int?
  reviewedById Int?

  manager    User?    @relation("ManagerProperties", fields: [managerId], references: [id], onDelete: SetNull)
  owner      User?    @relation("OwnedProperties", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy  User?    @relation("CreatedProperties", fields: [createdById], references: [id], onDelete: SetNull)
  reviewedBy User?    @relation("ReviewedProperties", fields: [reviewedById], references: [id], onDelete: SetNull)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Restrict)

  images       PropertyImage[]
  requests     Request[]
  favorites    Favorite[]
  reviews      Review[]
  transactions Transaction[]

  @@index([listingType])
  @@index([propertyType])
  @@index([rentPeriod])
  @@index([status])
  @@index([approvalStatus])
  @@index([managerId])
  @@index([locationId])
  @@index([ownerId])
  @@index([createdById])
  @@index([reviewedById])
  @@index([price])
  @@index([rooms])
  @@index([createdAt])
}

model Location {
  id        Int      @id @default(autoincrement())
  country   String   @db.VarChar(100)
  city      String   @db.VarChar(100)
  district  String?  @db.VarChar(100)
  street    String?  @db.VarChar(150)
  building  String?  @db.VarChar(50)
  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  properties Property[]

  @@index([city])
  @@index([district])
}

model PropertyImage {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String?  @db.VarChar(255)
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Request {
  id            Int           @id @default(autoincrement())
  type          RequestType
  message       String?
  preferredDate DateTime?
  status        RequestStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  userId     Int
  propertyId Int

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId     Int
  propertyId Int

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  userId     Int
  propertyId Int

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@index([createdAt])
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  senderId   Int
  receiverId Int

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Transaction {
  id        Int               @id @default(autoincrement())
  type      TransactionType
  status    TransactionStatus @default(PENDING)
  price     Decimal           @db.Decimal(12, 2)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  propertyId Int
  buyerId    Int
  sellerId   Int

  property Property @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  buyer    User     @relation("BuyerTransactions", fields: [buyerId], references: [id], onDelete: Restrict)
  seller   User     @relation("SellerTransactions", fields: [sellerId], references: [id], onDelete: Restrict)

  @@index([propertyId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}
